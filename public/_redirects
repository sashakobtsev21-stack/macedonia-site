# 301-редиректы Cloudflare (SPEC §7, CLAUDE правило 3).
# URL после индексации не меняются — исправления slug делаются ТОЛЬКО здесь.
# Формат:  /старый-путь/   /новый-путь/   301

# English стал языком по умолчанию (корень, 2026-06-16): прежние /en/-URL переехали
# на корень → 301 на тот же путь без префикса.
/en/* /:splat 301

# Сайт стал одноязычным (только en на корне, 2026-06-22): ru/uk удалены.
# Прежние /ru/* и /uk/* URL → 301 на тот же путь без языкового префикса (en на корне).
/ru/* /:splat 301
/uk/* /:splat 301
